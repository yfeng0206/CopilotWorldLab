<!--
  CopilotWorldLab step-1 pilot scene.

  A deliberately minimal tabletop: a free-floating "vial" (capped cylinder), a
  fixed square "holder" well with a few-millimetre clearance, and a mocap-driven
  end-effector proxy carrying a wrist camera. The mocap body gives us a clean
  7-DoF end-effector interface (xyz + orientation + gripper) that matches the
  V-JEPA 2-AC action space without needing a full arm + IK yet. A scene camera
  and a wrist camera provide the RGB observations / goal images the world model
  will consume later.

  Units: metres, radians, kilograms. No actuators in step 1 - the end-effector is
  kinematic (mocap) and the only dynamic body is the vial.
-->
<mujoco model="cwlab_pilot">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="implicitfast"/>

  <visual>
    <global offwidth="1280" offheight="1280"/>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.35 0.35 0.35" specular="0.1 0.1 0.1"/>
    <quality shadowsize="2048"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.45 0.6" rgb2="0.05 0.08 0.12"
             width="512" height="3072"/>
    <texture name="grid" type="2d" builtin="checker" mark="edge"
             rgb1="0.2 0.28 0.36" rgb2="0.12 0.18 0.24" markrgb="0.75 0.75 0.75"
             width="300" height="300"/>
    <material name="grid" texture="grid" texuniform="true" texrepeat="6 6" reflectance="0.15"/>
    <material name="table" rgba="0.82 0.76 0.66 1"/>
    <material name="vial_glass" rgba="0.55 0.78 0.9 0.55"/>
    <material name="vial_cap" rgba="0.12 0.12 0.14 1"/>
    <material name="holder" rgba="0.24 0.24 0.3 1"/>
    <material name="gripper" rgba="0.15 0.15 0.2 1"/>
  </asset>

  <worldbody>
    <light name="key" pos="0.3 -0.3 1.2" dir="-0.3 0.3 -1" diffuse="0.7 0.7 0.7"/>

    <geom name="floor" type="plane" size="0 0 0.05" material="grid"/>

    <!-- table top surface at z = 0.22 -->
    <body name="table" pos="0 0 0.2">
      <geom name="table_top" type="box" size="0.4 0.4 0.02" material="table"/>
    </body>

    <!-- fixed holder: a square well, inner opening ~0.04 m across (vial dia 0.024 m) -->
    <body name="holder" pos="-0.1 -0.1 0.22">
      <geom name="holder_base" type="box" size="0.03 0.03 0.005" pos="0 0 0.005" material="holder"/>
      <geom name="holder_wx" type="box" size="0.005 0.03 0.02" pos="0.025 0 0.025" material="holder"/>
      <geom name="holder_nx" type="box" size="0.005 0.03 0.02" pos="-0.025 0 0.025" material="holder"/>
      <geom name="holder_wy" type="box" size="0.03 0.005 0.02" pos="0 0.025 0.025" material="holder"/>
      <geom name="holder_ny" type="box" size="0.03 0.005 0.02" pos="0 -0.025 0.025" material="holder"/>
    </body>

    <!-- vial: the only dynamic object, starts above the table and settles -->
    <body name="vial" pos="0.1 0.1 0.28">
      <freejoint name="vial_free"/>
      <geom name="vial_body" type="cylinder" size="0.012 0.03" material="vial_glass" mass="0.02"/>
      <geom name="vial_cap" type="cylinder" size="0.012 0.006" pos="0 0 0.036" material="vial_cap" mass="0.005"/>
    </body>

    <!-- end-effector proxy: kinematic mocap body with a wrist camera looking down -->
    <body name="ee" mocap="true" pos="0.1 0.1 0.45">
      <geom name="ee_palm" type="box" size="0.02 0.03 0.01" material="gripper"/>
      <geom name="ee_finger_l" type="box" size="0.004 0.004 0.02" pos="0.016 0 -0.03" material="gripper"/>
      <geom name="ee_finger_r" type="box" size="0.004 0.004 0.02" pos="-0.016 0 -0.03" material="gripper"/>
      <camera name="wrist_cam" pos="0 0 0.0" fovy="60"/>
    </body>

    <!-- fixed overview camera aimed at the workspace -->
    <camera name="scene_cam" pos="0.55 -0.55 0.7" mode="targetbody" target="table"/>
  </worldbody>
</mujoco>
